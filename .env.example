# LocalFirst — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Resend API key — powers the contact form server action at
# app/contact/_actions/sendContact.js.
# Get a free key (3,000 emails / month) at https://resend.com/signup
# Without this set, the contact form falls back to "call instead" messaging.
RESEND_API_KEY=

# Google Places API key — powers the live Google reviews section on the
# homepage (app/components/Reviews.js → app/_data/reviews.js).
# Must be SERVER-side only (no HTTP-referer restriction) and restricted
# to the Places API. Get one at https://console.cloud.google.com/apis/credentials
# Without this set, the reviews section renders nothing (quiet failure).
GOOGLE_PLACES_API_KEY=
